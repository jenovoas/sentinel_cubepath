# Sentinel Ring-0 Configuration
# Copy this file to .env and fill in your values

# API Configuration
API_PORT=8000
RUST_LOG=info

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# CubePath Configuration
CUBEPATH_DOMAIN=sentinel.cubepath.app

# Security
JWT_SECRET=your-secret-key-here
CORS_ORIGIN=https://sentinel.cubepath.app