{
  "id": null,
  "uid": "sentinel-ring0-overview",
  "title": "Sentinel Ring-0 — Overview",
  "tags": ["sentinel", "ring0", "ebpf", "cubepath", "hackathon"],
  "style": "dark",
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "CPU Usage",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "RAM Usage",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "RAM %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Network In",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "irate(node_network_receive_bytes_total{device!=\"lo\"}[5m])",
          "legendFormat": "RX bytes/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Network Out",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "irate(node_network_transmit_bytes_total{device!=\"lo\"}[5m])",
          "legendFormat": "TX bytes/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU & RAM Timeline",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %"
        },
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "RAM %"
        }
      ]
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "S60 Resonance Score",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sentinel_resonance_score",
          "legendFormat": "Resonance"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "green", "value": 1000000 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "System Bio-Coherence",
      "gridPos": { "x": 8, "y": 12, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sentinel_bio_coherence",
          "legendFormat": "Coherence"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OFFLINE", "color": "red" }, "1": { "text": "STABLE", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Ring-0 Intercepts",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sentinel_ring0_intercepts_total",
          "legendFormat": "eBPF Blocked"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" } }
      }
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Sentinel Audit & Event Stream",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"sentinel-cortex\"} | json | line_format \"[S60-CORTEX] ⚡ RING-0 EVENT | LANE: {{.lane | upper}} | SIGNATURE: {{.nonce}} | ACTION: SANITIZED AND LOGGED\"",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false
      }
    }
  ],
  "time": { "from": "now-30m", "to": "now" }
}
